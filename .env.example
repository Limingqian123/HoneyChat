# .env.example
# HoneyChat 环境变量示例文件
# 复制为 .env 并根据需要修改

# ------------------------------
# 全局配置
# ------------------------------
LOG_LEVEL=INFO

# ------------------------------
# 蜜罐服务 (Honeypot) 配置
# 前缀: HONEYPOT_
# ------------------------------
HONEYPOT_SERVICE_NAME=honeychat-honeypot
HONEYPOT_LOG_LEVEL=INFO
HONEYPOT_SSH_HOST=0.0.0.0
HONEYPOT_SSH_PORT=2222
HONEYPOT_HTTP_HOST=0.0.0.0
HONEYPOT_HTTP_PORT=8080
HONEYPOT_RAG_ENGINE_URL=http://rag-engine:8000
HONEYPOT_DASHBOARD_URL=http://dashboard:5000
# 威胁情报 API 密钥（使用 VirusTotal API v3）
# 获取地址: https://www.virustotal.com/gui/my-apikey
# 示例: HONEYPOT_THREAT_INTEL_API_KEY=your_virustotal_api_key_here
HONEYPOT_THREAT_INTEL_API_KEY=
HONEYPOT_THREAT_INTEL_CACHE_TTL=3600
HONEYPOT_ENABLE_THREAT_INTEL=true
HONEYPOT_MAX_CONNECTIONS=100
HONEYPOT_CONNECTION_TIMEOUT=300
HONEYPOT_COMMAND_TIMEOUT=30
HONEYPOT_SESSION_IDLE_TIMEOUT=600
HONEYPOT_MAX_SESSION_HISTORY=1000
HONEYPOT_RAG_REQUEST_TIMEOUT=10
HONEYPOT_RAG_MAX_RETRIES=3

# ------------------------------
# RAG 引擎服务配置
# 前缀: RAG_ENGINE_
# ------------------------------
RAG_ENGINE_SERVICE_NAME=honeychat-rag-engine
RAG_ENGINE_LOG_LEVEL=INFO
RAG_ENGINE_HOST=0.0.0.0
RAG_ENGINE_PORT=8000
RAG_ENGINE_MODEL_PATH=/app/models/model.bin
RAG_ENGINE_MODEL_N_CTX=2048
RAG_ENGINE_MODEL_N_THREADS=4
RAG_ENGINE_MODEL_N_BATCH=512
RAG_ENGINE_MODEL_USE_MLOCK=false
RAG_ENGINE_MODEL_USE_MMAP=true
RAG_ENGINE_VECTOR_DB_PATH=/app/chroma_db
RAG_ENGINE_VECTOR_DB_COLLECTION=command_pairs
RAG_ENGINE_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_ENGINE_TOP_K=3
RAG_ENGINE_DATA_FILE=/app/data/command_pairs.json
RAG_ENGINE_MAX_TOKENS=256
RAG_ENGINE_TEMPERATURE=0.7
RAG_ENGINE_TOP_P=0.9
RAG_ENGINE_REPEAT_PENALTY=1.1

# ------------------------------
# Dashboard 服务配置
# 前缀: DASHBOARD_
# ------------------------------
DASHBOARD_SERVICE_NAME=honeychat-dashboard
DASHBOARD_LOG_LEVEL=INFO
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DASHBOARD_DEBUG=false
DASHBOARD_DATABASE_URL=sqlite:///data/events.db
DASHBOARD_DATABASE_POOL_SIZE=20
DASHBOARD_DATABASE_MAX_OVERFLOW=10
DASHBOARD_SECRET_KEY=dev-secret-key-change-in-production
DASHBOARD_SESSION_LIFETIME=86400
DASHBOARD_CORS_ORIGINS=*